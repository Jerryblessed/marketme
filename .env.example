# ── MarketMe — copy to .env and fill in values ──────────────────

NOVA_API_KEY=your-nova-api-key-here
SECRET_KEY=change-me-in-production

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///marketme.db

# SMTP (outbound email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com

# IMAP (inbox monitoring)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Public URL (used in miracle-link emails and live-chat widget)
APP_URL=http://localhost:5000

# Optional: path to shared contacts CSV (default: shared_contacts.csv)
# CSV_PATH=shared_contacts.csv
